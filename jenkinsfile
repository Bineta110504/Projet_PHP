pipeline {
    agent any
    environment {
        // Ici on définit tes secrets comme sur GitHub
        DOCKER_CREDS = credentials('docker-hub-credentials')
    }
    stages {
        stage('Checkout') {
            steps { checkout scm } // Il récupère ton code PHP
        }
        stage('Build & Push') {
            steps {
                // Il utilise ton Dockerfile pour créer l'image
                sh "docker build -t ${DOCKER_CREDS_USR}/projet-php:latest ."
                sh "echo ${DOCKER_CREDS_PSW} | docker login -u ${DOCKER_CREDS_USR} --password-stdin"
                sh "docker push ${DOCKER_CREDS_USR}/projet-php:latest"
            }
        }
    }
}